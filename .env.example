# ============================================================================
# Anna — Environment Variables
# ============================================================================
# Zkopíruj tento soubor jako .env.local a doplň reálné hodnoty.
# .env.local NIKDY necommitovat (je v .gitignore).
# ============================================================================

# ----------------------------------------------------------------------------
# OpenAI — Whisper transkripce (Whisper-1) a GPT-4o extrakce/generování
# ----------------------------------------------------------------------------
# Použito v: src/lib/openai/* (server-side only)
# Získej na: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ----------------------------------------------------------------------------
# Supabase — public URL projektu
# ----------------------------------------------------------------------------
# Použito v: client i server (proto NEXT_PUBLIC_)
# Najdi v: Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# ----------------------------------------------------------------------------
# Supabase — anon (public) key
# ----------------------------------------------------------------------------
# Použito v: client + server. Bezpečné pro browser — RLS policies chrání data.
# Najdi v: Supabase Dashboard → Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# ----------------------------------------------------------------------------
# Supabase — service role key (BYPASSUJE RLS!)
# ----------------------------------------------------------------------------
# SERVER-SIDE ONLY. NIKDY v klient kódu, NIKDY v NEXT_PUBLIC_*.
# Použij pro: admin panel queries, batch operations, super-admin akce.
# Najdi v: Supabase Dashboard → Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ----------------------------------------------------------------------------
# Resend — transactional email
# ----------------------------------------------------------------------------
# Použito v: pozvánky pro zákazníky, magic link emaily (později).
# Pro prototyp není kritické.
# Získej na: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ============================================================================
# MCP server credentials (pro Claude Code, ne pro aplikaci)
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase MCP — personal access token
# ----------------------------------------------------------------------------
# Použito v: .mcp.json pro Claude Code introspekci DB.
# NENÍ to project anon/service key — je to access token tvého Supabase účtu.
# Vytvoř na: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_...

# ----------------------------------------------------------------------------
# Supabase MCP — project ref
# ----------------------------------------------------------------------------
# 24-znakový ID projektu (najdeš v URL Supabase dashboardu).
# Příklad: https://supabase.com/dashboard/project/abcdefghijklmnopqrstuvwx
#          → SUPABASE_PROJECT_REF=abcdefghijklmnopqrstuvwx
SUPABASE_PROJECT_REF=...
